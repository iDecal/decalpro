---
import BaseLayout from "../../layouts/BaseLayout.astro";

// 🔥 PHẢI đặt trên cùng (QUAN TRỌNG)
const districts = [
  "quan-1","quan-2","quan-3","quan-4","quan-5","quan-6","quan-7","quan-8",
  "quan-9","quan-10","quan-11","quan-12",
  "binh-thanh","phu-nhuan","tan-binh","tan-phu","binh-tan",
  "thu-duc","hoc-mon","cu-chi","binh-chanh","nha-be","can-gio"
];

// 🔥 KHÔNG được đặt trước districts
export function getStaticPaths() {
  return districts.map((slug) => ({
    params: { district: slug },
    props: { slug }
  }));
}

const { slug } = Astro.props;

// format tên
function formatName(slug) {
  const map = {
    "binh-thanh": "Bình Thạnh",
    "phu-nhuan": "Phú Nhuận",
    "tan-binh": "Tân Bình",
    "tan-phu": "Tân Phú",
    "binh-tan": "Bình Tân",
    "thu-duc": "TP Thủ Đức",
    "hoc-mon": "Hóc Môn",
    "cu-chi": "Củ Chi",
    "binh-chanh": "Bình Chánh",
    "nha-be": "Nhà Bè",
    "can-gio": "Cần Giờ"
  };

  if (slug.startsWith("quan-")) {
    return "Quận " + slug.replace("quan-", "");
  }

  return map[slug] || slug;
}

const districtName = formatName(slug);
---

<BaseLayout
  title={`Thi công decal dán kính ${districtName}`}
  description={`Dịch vụ decal dán kính ${districtName} chuyên nghiệp`}
>

<section class="py-20 text-center">
  <h1 class="text-4xl font-bold mb-6">
    Thi công decal dán kính {districtName}
  </h1>

  <p class="text-gray-600 max-w-2xl mx-auto">
    Không gian tại {districtName} mang một nhịp sống riêng —
    và mỗi lớp decal là một cách để giữ lại ánh sáng,
    nhưng dịu đi cái nhìn, và làm mềm đi cái nắng.
  </p>
</section>

</BaseLayout>
