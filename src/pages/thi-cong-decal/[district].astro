---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { districtMega } from "../../lib/districtMega";

export async function getStaticPaths() {
  const allDistricts = districtMega.flatMap(group => group.districts);
  
  return allDistricts.map((d) => ({
    params: { district: d.slug },
    props: { 
      info: d // Truyền toàn bộ đối tượng d (chứa seoContent, projects...) vào props
    },
  }));
}

const { info } = Astro.props;
---

<BaseLayout title={`Thi công decal tại ${info.name}`}>
  <section class="py-20 px-6">
    <h1>Dịch vụ tại {info.name}</h1>
    
    <div class="prose max-w-4xl mx-auto">
      <p>{info.seoContent}</p> 
    </div>

    <div class="mt-10">
      <h3 class="font-bold">Công trình đã làm tại {info.name}:</h3>
      <ul>
        {info.projects?.map(p => <li>{p}</li>)}
      </ul>
    </div>
  </section>
</BaseLayout>
