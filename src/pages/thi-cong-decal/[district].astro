---
import BaseLayout from "../../layouts/BaseLayout.astro";

// ✅ TẤT CẢ phải nằm trong 1 block --- DUY NHẤT
const districts = [
  "quan-1","quan-2","quan-3","quan-4","quan-5","quan-6","quan-7","quan-8",
  "quan-9","quan-10","quan-11","quan-12",
  "binh-thanh","phu-nhuan","tan-binh","tan-phu","binh-tan",
  "thu-duc","hoc-mon","cu-chi","binh-chanh","nha-be","can-gio"
];

export function getStaticPaths() {
  return districts.map((slug) => ({
    params: { district: slug },
    props: { slug }
  }));
}

const { slug } = Astro.props;

function formatName(slug) {
  const map = {
    "binh-thanh": "Bình Thạnh",
    "phu-nhuan": "Phú Nhuận",
    "tan-binh": "Tân Bình",
    "tan-phu": "Tân Phú",
    "binh-tan": "Bình Tân",
    "thu-duc": "TP Thủ Đức",
    "hoc-mon": "Hóc Môn",
    "cu-chi": "Củ Chi",
    "binh-chanh": "Bình Chánh",
    "nha-be": "Nhà Bè",
    "can-gio": "Cần Giờ"
  };

  if (slug.startsWith("quan-")) {
    return "Quận " + slug.replace("quan-", "");
  }

  return map[slug] || slug;
}

const districtName = formatName(slug);
---

<BaseLayout title={`Thi công decal dán kính ${districtName}`}>

<section class="py-20 text-center">
  <h1 class="text-4xl font-bold">
    Thi công decal dán kính {districtName}
  </h1>
</section>

</BaseLayout>
