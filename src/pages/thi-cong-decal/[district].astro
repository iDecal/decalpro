---
import BaseLayout from "../../layouts/BaseLayout.astro";

// ✅ PHẢI đặt TRƯỚC getStaticPaths
const districts = [
  "quan-1","quan-2","quan-3","quan-4","quan-5","quan-6","quan-7","quan-8",
  "quan-9","quan-10","quan-11","quan-12",
  "binh-thanh","phu-nhuan","tan-binh","tan-phu","binh-tan",
  "thu-duc","hoc-mon","cu-chi","binh-chanh","nha-be","can-gio"
];

// ✅ Astro cần cái này để build static
export async function getStaticPaths() {
  return districts.map((slug) => ({
    params: { district: slug },
    props: { slug }
  }));
}

const { slug } = Astro.props;

// 🌿 Format tên
function formatName(slug) {
  return slug
    .replace("quan-", "Quận ")
    .replace("binh-thanh", "Bình Thạnh")
    .replace("phu-nhuan", "Phú Nhuận")
    .replace("tan-binh", "Tân Bình")
    .replace("tan-phu", "Tân Phú")
    .replace("binh-tan", "Bình Tân")
    .replace("thu-duc", "TP Thủ Đức")
    .replace("hoc-mon", "Hóc Môn")
    .replace("cu-chi", "Củ Chi")
    .replace("binh-chanh", "Bình Chánh")
    .replace("nha-be", "Nhà Bè")
    .replace("can-gio", "Cần Giờ");
}

const districtName = formatName(slug);
---

<BaseLayout
  title={`Thi công decal dán kính ${districtName}`}
  description={`Dịch vụ decal dán kính ${districtName} chuyên nghiệp`}
>

<section class="py-20 text-center">
  <h1 class="text-4xl font-bold mb-6">
    Thi công decal dán kính {districtName}
  </h1>

  <p class="text-gray-600 max-w-2xl mx-auto">
    Mỗi khu vực tại {districtName} mang một nhịp sống riêng —
    và decal dán kính chính là lớp chuyển mình nhẹ nhàng,
    giúp không gian vừa riêng tư, vừa tinh tế.
  </p>
</section>

</BaseLayout>
