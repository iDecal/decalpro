---
import { getCollection } from 'astro:content';
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const khuVucEntries = await getCollection('khu-vuc');
  return khuVucEntries.map(entry => ({
    params: { district: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, districtName, description } = entry.data;
---

<BaseLayout title={title} description={description}>
  
  <section class="py-24 text-center bg-gray-50">
    <h1 class="text-4xl md:text-5xl font-bold mb-6">{title}</h1>
    <p class="max-w-2xl mx-auto text-gray-600">
      Giải pháp dán kính thẩm mỹ và chống nóng tại {districtName}.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </section>

  </BaseLayout>
