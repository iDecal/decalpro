---
import BaseLayout from "../layouts/BaseLayout.astro";
import { districtMega } from "../lib/districtMega";

// 1. Dữ liệu Dịch vụ chính (PHẦN MỚI THÊM)
const mainServices = [
  {
    title: "Dán kính văn phòng",
    desc: "Giải pháp tạo không gian riêng tư, chuyên nghiệp cho doanh nghiệp.",
    priceNote: "Giá chỉ từ 40.000đ/m²",
    icon: "🏢",
    link: "/decal-dan-kinh-van-phong"
  },
  {
    title: "Chống nắng cách nhiệt",
    desc: "Giảm nhiệt độ phòng, bảo vệ sức khỏe và nội thất khỏi tia UV.",
    priceNote: "Giá chỉ từ 65.000đ/m²",
    icon: "☀️",
    link: "/thi-cong-phim-cach-nhiet"
  },
  {
    title: "Decal quảng cáo",
    desc: "Thiết kế và thi công cắt dán logo, slogan theo yêu cầu thương hiệu.",
    priceNote: "Giá chỉ từ 120.000đ/m²",
    icon: "✂️",
    link: "/decal-quang-cao"
  },
  {
    title: "Wrap nội thất",
    desc: "Dán film đổi màu nội thất vân gỗ, vân đá cao cấp cho tủ bếp, bàn ghế.",
    priceNote: "Giá chỉ từ 250.000đ/m²",
    icon: "🎨",
    link: "/wrap-noi-that"
  }
];

// 2. Dữ liệu Dự án đã thi công (DỮ LIỆU CŨ CỦA BẠN)
const projects = [
  {
    title: "Thi công Decal kính FD Care Quận 9 - Vinhomes grandPark",
    location: "KĐT Vinhomes, Quận 9, TP.HCM",
    image: "/images/decal-dan-kinh-FDcare-quan-9.jpg",
    category: "Showroom"
  },
  {
    title: "Dán decal mờ văn phòng ngân hàng Vietcombank",
    location: "Quận 1, TP.HCM",
    image: "/images/projects/vcb-quan-1.jpg",
    category: "Văn phòng"
  },
  {
    title: "Chống nắng kính căn hộ Landmark 81",
    location: "Bình Thạnh, TP.HCM",
    image: "/images/projects/landmark-81.jpg",
    category: "Căn hộ"
  },
  {
    title: "Trang trí decal tết cho quán Cafe Highlands",
    location: "Quận 3, TP.HCM",
    image: "/images/thi-cong-decal-dan-kinh-quan-tra-sua-half-n-half.jpg",
    category: "Trang trí"
  }
];

// 3. Dữ liệu FAQ chuẩn SEO (DỮ LIỆU CŨ CỦA BẠN)
const faqs = [
  {
    q: "Giá thi công dán kính tính theo m2 hay theo tấm?",
    a: "Thông thường, chi phí sẽ được tính theo m2 hoàn thiện (bao gồm vật tư và công thợ). Với diện tích nhỏ dưới 5m2, chúng tôi áp dụng mức giá trọn gói để tối ưu nhất cho khách hàng."
  },
  {
    q: "Thời gian bảo hành thi công là bao lâu?",
    a: "Tất cả công trình đều được bảo hành từ 2 - 5 năm đối với các lỗi kỹ thuật như bong tróc hay nổi bọt khí."
  },
  {
    q: "Thợ có mặt khảo sát sau bao lâu?",
    a: "Tại nội thành TP.HCM, đội ngũ kỹ thuật sẽ có mặt trong vòng 30 - 60 phút để đo đạc và tư vấn mẫu trực tiếp."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
---

<BaseLayout 
  title="Thi Công Decal Dán Kính Chuyên Nghiệp TP.HCM - Khảo Sát Tận Nơi"
  description="Dịch vụ thi công decal dán kính văn phòng, decal mờ, phim cách nhiệt tại TP.HCM. Thợ tay nghề cao, thi công nhanh, bảo hành 2 năm."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />

  <section class="relative bg-slate-900 py-20 px-6 overflow-hidden">
    <div class="max-w-7xl mx-auto relative z-10 flex flex-col md:flex-row items-center gap-12">
      <div class="flex-1 text-center md:text-left text-white">
        <span class="bg-yellow-500 text-black px-4 py-1 rounded-full text-sm font-bold uppercase mb-4 inline-block">Uy tín số 1 TP.HCM</span>
        <h1 class="text-3xl md:text-6xl font-extrabold leading-tight mb-6">
          Thi công Decal Dán Kính <br/> <span class="text-yellow-400">Chuyên Nghiệp</span> TP. HCM
        </h1>
        <p class="text-lg text-slate-300 mb-8 max-w-xl">
          Đội ngũ chuyên thi công decal văn phòng, chống nắng căn hộ và trang trí showroom. Khảo sát tận nhà, thi công trong ngày.
        </p>
        <div class="flex flex-wrap justify-center md:justify-start gap-4">
          <a href="tel:0862208108" class="bg-yellow-500 text-black px-8 py-4 rounded-lg font-bold text-lg hover:scale-105 transition shadow-lg">
            📞 Hotline: 0862-208-108
          </a>
        </div>
      </div>
      <div class="flex-1 w-full">
        <img src="/images/Thi-cong-dan-phim-cach-nhiet-van-phong-cong-ty.webp" alt="Thi công decal dán kính" class="rounded-2xl shadow-2xl border-4 border-white/10" />
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-black text-slate-900 mb-4">DỊCH VỤ <span class="text-yellow-500">TRỌNG TÂM</span></h2>
        <div class="w-20 h-1.5 bg-yellow-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {mainServices.map((service) => (
          <a href={service.link} class="group bg-slate-50 p-8 rounded-[2rem] border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-yellow-500/10 transition-all duration-500 flex flex-col">
            <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">{service.icon}</div>
            <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-yellow-600 transition">{service.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed mb-6 flex-grow">{service.desc}</p>
            <div class="pt-5 border-t border-slate-200">
              <span class="block text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-1">Chi phí từ</span>
              <span class="text-lg font-black text-slate-900">{service.priceNote}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50 px-6">
    <div class="max-w-7xl mx-auto text-center md:text-left mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Dự án tiêu biểu</h2>
        <p class="text-gray-600 italic">"Sắc nét từng đường cắt - Bền bỉ theo thời gian"</p>
    </div>
    <div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {projects.map((project) => (
          <div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all">
            <div class="relative overflow-hidden aspect-[4/3]">
              <img src={project.image} alt={project.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
              <span class="absolute top-3 left-3 bg-black/60 text-white text-[10px] px-2 py-1 rounded-full">{project.category}</span>
            </div>
            <div class="p-5">
              <h3 class="font-bold text-md mb-2 line-clamp-2">{project.title}</h3>
              <p class="text-gray-500 text-xs flex items-center gap-1">📍 {project.location}</p>
            </div>
          </div>
        ))}
    </div>
  </section>

  <section class="py-16 bg-white px-6">
    <div class="max-w-7xl mx-auto text-center mb-10">
      <h2 class="text-2xl font-bold">Khu vực phục vụ 24/7</h2>
    </div>
    <div class="flex flex-wrap justify-center gap-2 max-w-5xl mx-auto">
      {districtMega.flatMap(g => g.districts).map(d => (
        <a href={`/thi-cong-decal/${d.slug}`} class="bg-gray-100 px-4 py-2 rounded-lg text-sm hover:bg-yellow-400 transition font-medium">
          {d.name}
        </a>
      ))}
    </div>
  </section>

  <section class="py-20 px-6 bg-gray-50">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">Hỏi đáp dịch vụ</h2>
      <div class="space-y-6">
        {faqs.map(item => (
          <div class="bg-white p-6 rounded-xl shadow-sm">
            <h3 class="text-lg font-bold mb-2 flex gap-2">
              <span class="text-yellow-600">Q:</span> {item.q}
            </h3>
            <p class="text-gray-600 pl-6 border-l-2 border-yellow-500 ml-2">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-yellow-400 py-16 text-center px-6">
    <h2 class="text-3xl font-bold mb-4">Bạn cần tư vấn mẫu ngay tại nhà?</h2>
    <p class="mb-8 font-medium">Khảo sát đo đạc miễn phí - Báo giá không phát sinh</p>
    <a href="tel:0862208108" class="bg-black text-white px-10 py-4 rounded-full font-bold text-xl inline-block hover:scale-110 transition">
        Liên hệ ngay: 0862-208-108
    </a>
  </section>
</BaseLayout>
