---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Liên hệ thi công decal TP.HCM" description="Liên hệ thi công decal dán kính nhanh chóng tại TP.HCM. Gọi ngay 0862-208-108 để được tư vấn và báo giá.">

  <!-- HERO -->
  <section class="bg-green-600 text-white py-20 px-6 text-center">
    <h1 class="text-4xl font-bold mb-4">Liên Hệ Thi Công Decal</h1>
    <p class="text-lg">Nhanh chóng – tận nơi – tư vấn miễn phí</p>
  </section>

  <!-- CONTACT INFO -->
  <section class="py-16 px-6 max-w-5xl mx-auto grid md:grid-cols-2 gap-10">
    <div>
      <h2 class="text-2xl font-bold mb-6">Thông tin liên hệ</h2>
      <p class="mb-3">📞 Hotline: <a href="tel:0862208108" class="text-green-600 font-semibold">0862-208-108</a></p>
      <p class="mb-3">💬 Zalo: <a href="https://zalo.me/0862208108" class="text-green-600">Chat ngay</a></p>
      <p class="mb-3">📧 Email: lienhe@thicongdecal.pro</p>
      <p class="mb-3">📍 Địa chỉ: 606/20 Quốc lộ 13, P. Hiệp Bình, TP.HCM</p>
    </div>

    <!-- FORM -->
    <form class="bg-white p-6 rounded-2xl shadow space-y-4">
      <input type="text" placeholder="Tên của bạn" class="w-full border p-3 rounded-xl" required />
      <input type="tel" placeholder="Số điện thoại" class="w-full border p-3 rounded-xl" required />
      <textarea placeholder="Nhu cầu thi công decal" class="w-full border p-3 rounded-xl"></textarea>
      <button class="w-full bg-green-600 text-white py-3 rounded-xl">Gửi yêu cầu</button>
    </form>
  </section>

  <!-- MAP -->
  <section class="py-10 px-6 max-w-5xl mx-auto">
    <iframe
      src="https://www.google.com/maps?q=606/20+Quoc+lo+13+Hiep+Binh+TPHCM&output=embed"
      class="w-full h-80 rounded-2xl border"
      loading="lazy">
    </iframe>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-10">Câu hỏi thường gặp</h2>
      <div class="space-y-6">

        <div>
          <h3 class="font-semibold">Thi công decal mất bao lâu?</h3>
          <p>Thông thường từ 1–3 giờ tùy diện tích và độ phức tạp.</p>
        </div>

        <div>
          <h3 class="font-semibold">Có hỗ trợ ngoài giờ không?</h3>
          <p>Có, chúng tôi thi công buổi tối và cuối tuần.</p>
        </div>

        <div>
          <h3 class="font-semibold">Có cần đặt lịch trước không?</h3>
          <p>Nên đặt lịch trước để được phục vụ nhanh và đúng thời gian mong muốn.</p>
        </div>

        <div>
          <h3 class="font-semibold">Decal có bền không?</h3>
          <p>Tuổi thọ trung bình từ 2–5 năm tùy loại và môi trường sử dụng.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-green-600 text-white py-16 text-center">
    <h2 class="text-3xl font-bold mb-4">Cần thi công decal ngay?</h2>
    <p class="mb-6">Gọi ngay để được tư vấn nhanh nhất</p>
    <a href="tel:0862208108" class="bg-white text-green-600 px-8 py-3 rounded-2xl">Gọi 0862-208-108</a>
  </section>

</BaseLayout>
