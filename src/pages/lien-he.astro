---
import BaseLayout from "../../layouts/BaseLayout.astro";

// 1. Dữ liệu FAQ dành riêng cho trang liên hệ
const contactFaqs = [
  {
    q: "Phí khảo sát tận nơi tại TP.HCM là bao nhiêu?",
    a: "Chúng tôi hỗ trợ khảo sát, đo đạc và mang mẫu tận nơi miễn phí hoàn toàn tại tất cả các quận huyện thuộc TP.HCM."
  },
  {
    q: "Tôi có thể nhận báo giá qua Zalo không?",
    a: "Có. Bạn chỉ cần chụp ảnh mặt bằng và gửi số đo sơ bộ qua Zalo, chúng tôi sẽ phản hồi báo giá dự toán sau 5-10 phút."
  },
  {
    q: "Công ty có xuất hóa đơn VAT không?",
    a: "Có. Chúng tôi hỗ trợ xuất hóa đơn tài chính đầy đủ cho các đơn vị doanh nghiệp, văn phòng khi thi công decal."
  }
];

// 2. Schema LocalBusiness & FAQ (Giúp Google hiểu đây là trang liên hệ chính thức)
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "Decal Pro",
      "image": "/images/DecalPro.png",
      "telephone": "0862208108",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Ho Chi Minh City",
        "addressCountry": "VN"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": contactFaqs.map(item => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.a
        }
      }))
    }
  ]
};
---

<BaseLayout 
  title="Liên Hệ Thi Công Decal Dán Kính - Tư Vấn & Báo Giá Miễn Phí"
  description="Liên hệ ngay với chúng tôi để được tư vấn dán kính văn phòng, chống nắng căn hộ tận nơi tại TP.HCM. Hotline 24/7: 0862 208 108."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <section class="bg-slate-900 py-16 text-center text-white px-6">
    <h1 class="text-4xl font-bold mb-4">Liên Hệ Đội Ngũ Kỹ Thuật</h1>
    <p class="max-w-2xl mx-auto text-slate-300">
      Đừng ngần ngại liên hệ để nhận tư vấn mẫu decal phù hợp và báo giá tối ưu nhất cho không gian của bạn.
    </p>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-16 grid md:grid-cols-2 gap-16">
    <div>
      <h2 class="text-2xl font-bold mb-8">Thông tin trực tiếp</h2>
      
      <div class="space-y-8">
        <div class="flex items-start gap-4">
          <div class="bg-yellow-100 p-3 rounded-lg text-yellow-700">📞</div>
          <div>
            <p class="font-bold text-lg">Hotline / Zalo (24/7)</p>
            <a href="tel:0862208108" class="text-2xl font-extrabold text-yellow-600">0862 208 108</a>
            <p class="text-gray-500 text-sm italic">Hỗ trợ tư vấn nhanh mọi lúc.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="bg-yellow-100 p-3 rounded-lg text-yellow-700">🕒</div>
          <div>
            <p class="font-bold text-lg">Thời gian làm việc</p>
            <p class="text-gray-700">Thứ 2 - Chủ Nhật: 08:00 - 21:00</p>
            <p class="text-gray-500 text-sm">(Hỗ trợ thi công ngoài giờ cho văn phòng/mall)</p>
          </div>
        </div>
      </div>

      <div class="mt-16">
        <h3 class="text-xl font-bold mb-6">Giải đáp nhanh</h3>
        <div class="space-y-6">
          {contactFaqs.map(faq => (
            <div class="border-l-4 border-yellow-500 pl-4">
              <p class="font-bold text-slate-800 mb-1">{faq.q}</p>
              <p class="text-gray-600 text-sm">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
      <h2 class="text-2xl font-bold mb-6">Gửi yêu cầu báo giá</h2>
      <form action="#" class="space-y-4">
        <div>
          <label class="block text-sm font-bold mb-1">Họ tên khách hàng *</label>
          <input type="text" placeholder="Nguyễn Văn A" class="w-full px-4 py-3 rounded-lg border focus:ring-2 focus:ring-yellow-400 outline-none" required />
        </div>
        <div>
          <label class="block text-sm font-bold mb-1">Số điện thoại *</label>
          <input type="tel" placeholder="09xx xxx xxx" class="w-full px-4 py-3 rounded-lg border focus:ring-2 focus:ring-yellow-400 outline-none" required />
        </div>
        <div>
          <label class="block text-sm font-bold mb-1">Địa chỉ thi công (Quận/Huyện)</label>
          <input type="text" placeholder="Quận 1, Quận 7..." class="w-full px-4 py-3 rounded-lg border focus:ring-2 focus:ring-yellow-400 outline-none" />
        </div>
        <div>
          <label class="block text-sm font-bold mb-1">Nội dung yêu cầu</label>
          <textarea rows="4" placeholder="Ví dụ: Dán decal mờ văn phòng diện tích 20m2..." class="w-full px-4 py-3 rounded-lg border focus:ring-2 focus:ring-yellow-400 outline-none"></textarea>
        </div>
        <button type="submit" class="w-full bg-slate-900 text-white py-4 rounded-lg font-bold text-lg hover:bg-black transition">
          GỬI YÊU CẦU NGAY
        </button>
      </form>
    </div>
  </section>

</BaseLayout>
