---
import BaseLayout from "../layouts/BaseLayout.astro";

// Dữ liệu bảng giá chi tiết
const pricingSections = [
  {
    title: "Báo Giá Decal Mờ Văn Phòng",
    description: "Giải pháp hàng đầu cho vách kính phòng họp, phòng làm việc nhân viên.",
    items: [
      { name: "Decal mờ dán trơn (Standard)", price: "40.000 - 60.000", unit: "m2" },
      { name: "Decal mờ kẻ chỉ thủ công", price: "80.000 - 110.000", unit: "m2" },
      { name: "Cắt chữ/Logo decal mờ CNC", price: "120.000 - 350.000", unit: "bộ" },
      { name: "In UV màu trên nền decal mờ", price: "180.000 - 280.000", unit: "m2" }
    ],
    image: "/images/projects/decal-mo-van-phong.jpg" // Đảm bảo có ảnh này
  },
  {
    title: "Báo Giá Phim Cách Nhiệt - Chống Nắng",
    description: "Ngăn tia UV, giảm nhiệt độ phòng và tiết kiệm điện năng cho điều hòa.",
    items: [
      { name: "Decal phản quang (Silver)", price: "60.000 - 90.000", unit: "m2" },
      { name: "Phim cách nhiệt Nano Ceramic (Hàn Quốc)", price: "250.000 - 450.000", unit: "m2" },
      { name: "Phim cách nhiệt 3M chính hãng", price: "550.000 - 1.200.000", unit: "m2" },
      { name: "Phim an toàn (Safety Film) chống vỡ kính", price: "180.000 - 320.000", unit: "m2" }
    ],
    image: "/images/projects/phim-cach-nhiet.jpg"
  },
  {
    title: "Dịch Vụ Wrap & Decal Quảng Cáo",
    description: "Tân trang nội thất và quảng bá thương hiệu mặt tiền Showroom.",
    items: [
      { name: "Wrap film nội thất (Vân gỗ, vân đá)", price: "250.000 - 600.000", unit: "m2" },
      { name: "Decal lưới (One-way Vision) in quảng cáo", price: "150.000 - 220.000", unit: "m2" },
      { name: "Tháo gỡ decal cũ & vệ sinh keo", price: "20.000 - 45.000", unit: "m2" }
    ],
    image: "/images/projects/wrap-noi-that.jpg"
  }
];

const checklistSEO = [
    "Khảo sát đo đạc mặt bằng miễn phí 100%.",
    "Đội ngũ kỹ thuật viên hơn 5 năm kinh nghiệm.",
    "Sử dụng vật liệu chính hãng, độ bền trên 5 năm.",
    "Thi công sạch sẽ, nhanh chóng, kể cả ngoài giờ hành chính.",
    "Có đầy đủ hóa đơn VAT cho doanh nghiệp."
];
---

<BaseLayout 
  title="Báo Giá Thi Công Decal Dán Kính, Phim Cách Nhiệt TPHCM 2026"
  description="Cập nhật bảng giá dán decal mờ văn phòng, cắt logo kính, dán phim cách nhiệt nhà kính giá rẻ tại TPHCM. Cam kết không phát sinh, khảo sát miễn phí."
>
  <section class="relative py-20 bg-slate-900 text-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6">Báo Giá Thi Công Decal & Phim Cách Nhiệt</h1>
      <p class="text-xl text-slate-400 max-w-3xl">
        Cung cấp báo giá chi tiết cho dịch vụ dán kính văn phòng, căn hộ tại TP.HCM. 
        Chúng tôi cam kết mang lại giải pháp tối ưu với mức chi phí hợp lý nhất.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      {pricingSections.map((section, index) => (
        <div class={`flex flex-col lg:flex-row gap-12 mb-24 items-center ${index % 2 !== 0 ? 'lg:flex-row-reverse' : ''}`}>
          <div class="flex-1 w-full">
            <h2 class="text-3xl font-bold mb-4 text-slate-800">{section.title}</h2>
            <p class="text-gray-600 mb-8">{section.description}</p>
            
            <div class="overflow-x-auto border border-gray-100 rounded-2xl shadow-sm">
              <table class="w-full text-left border-collapse">
                <thead class="bg-slate-50">
                  <tr>
                    <th class="p-4 font-bold text-slate-700">Hạng mục thi công</th>
                    <th class="p-4 font-bold text-slate-700 text-right">Đơn giá (VNĐ)</th>
                  </tr>
                </thead>
                <tbody>
                  {section.items.map((item) => (
                    <tr class="border-t border-gray-50 hover:bg-gray-50 transition">
                      <td class="p-4 text-gray-700">{item.name}</td>
                      <td class="p-4 text-right">
                        <span class="font-bold text-slate-900 text-lg">{item.price}</span>
                        <span class="text-gray-400 text-sm italic"> /{item.unit}</span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="mt-4 text-xs text-gray-400 italic font-light">
                * Lưu ý: Đơn giá trên có tính chất tham khảo cho khối lượng >20m2. Khối lượng ít hơn hoặc vị trí khó thi công (trên cao, ban đêm) vui lòng liên hệ.
            </p>
          </div>
          
          <div class="flex-1 w-full">
            <div class="relative group">
                <div class="absolute -inset-2 bg-yellow-400 rounded-2xl blur opacity-20 group-hover:opacity-40 transition"></div>
                <img 
                    src={section.image} 
                    alt={section.title} 
                    class="relative rounded-2xl shadow-xl w-full h-[400px] object-cover"
                />
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="py-20 bg-slate-50 px-6">
    <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">Yếu tố nào ảnh hưởng đến giá thi công decal?</h2>
        <div class="prose prose-slate max-w-none text-gray-600 space-y-6">
            <p>
                Khi tìm kiếm đơn vị <strong>thi công decal dán kính</strong>, quý khách thường thấy có nhiều mức giá khác nhau. Tại <strong>DecalPro</strong>, chúng tôi luôn minh bạch các yếu tố ảnh hưởng trực tiếp đến ngân sách của bạn:
            </p>
            <ul class="list-disc pl-6 space-y-4">
                <li><strong>Diện tích thi công:</strong> Khối lượng càng lớn, đơn giá trên mỗi mét vuông càng giảm sâu.</li>
                <li><strong>Độ khó của thiết kế:</strong> Decal mờ dán trơn sẽ rẻ hơn so với decal cắt chữ, logo CNC hoặc kẻ chỉ thủ công đòi hỏi sự tỉ mỉ.</li>
                <li><strong>Chất lượng vật liệu:</strong> Phim cách nhiệt Nano Ceramic chính hãng Hàn Quốc sẽ có giá cao hơn các dòng decal phản quang thông thường nhưng hiệu quả cản nhiệt vượt trội.</li>
                <li><strong>Vị trí thi công:</strong> Các vị trí trên cao cần giàn giáo hoặc dán ngoài giờ hành chính sẽ phát sinh thêm phụ phí hỗ trợ thợ.</li>
            </ul>
        </div>
    </div>
  </section>

  <section class="py-20 bg-white px-6">
    <div class="max-w-7xl mx-auto border-2 border-dashed border-slate-200 rounded-3xl p-8 md:p-16">
        <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
                <h2 class="text-3xl font-bold mb-8">Cam kết dịch vụ tại DecalPro</h2>
                <ul class="space-y-4">
                    {checklistSEO.map(item => (
                        <li class="flex items-center gap-3">
                            <span class="text-green-500 text-xl">✔</span>
                            <span class="text-gray-700 font-medium">{item}</span>
                        </li>
                    ))}
                </ul>
            </div>
            <div class="bg-slate-900 rounded-2xl p-8 text-white">
                <h3 class="text-2xl font-bold mb-4">Nhận báo giá ngay qua Zalo</h3>
                <p class="text-slate-400 mb-8 text-sm">Chụp ảnh mặt bằng kính và gửi kích thước sơ bộ, chúng tôi sẽ gửi báo giá trọn gói không phát sinh trong 5 phút.</p>
                <a href="https://zalo.me/0862208108" class="block w-full text-center bg-yellow-500 text-black py-4 rounded-xl font-bold text-xl hover:bg-yellow-400 transition">
                    Zalo: 0862 208 108
                </a>
            </div>
        </div>
    </div>
  </section>
</BaseLayout>
