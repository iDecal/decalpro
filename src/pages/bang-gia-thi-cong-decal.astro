---
import BaseLayout from "../layouts/BaseLayout.astro";

// Dữ liệu bảng giá chi tiết - Cập nhật 4 mục
const pricingSections = [
  {
    title: "Báo Giá Decal Mờ Văn Phòng",
    link: "/dich-vu/decal-dan-kinh-van-phong/",
    description: "Giải pháp hàng đầu cho vách kính phòng họp, tạo không gian riêng tư và chuyên nghiệp.",
    items: [
      { name: "Decal mờ dán trơn (Standard)", price: "40.000 - 60.000", unit: "m2" },
      { name: "Decal mờ kẻ chỉ thủ công", price: "80.000 - 110.000", unit: "m2" },
      { name: "Cắt chữ/Logo decal mờ CNC", price: "120.000 - 350.000", unit: "bộ" },
      { name: "In UV màu trên nền decal mờ", price: "180.000 - 280.000", unit: "m2" }
    ],
    image: "/images/projects/decal-mo-van-phong.jpg" 
  },
  {
    title: "Báo Giá Phim Cách Nhiệt - Chống Nắng",
    link: "/dich-vu/decal-chong-nang-cach-nhiet/",
    description: "Ngăn tia UV 99%, giảm nhiệt độ phòng và bảo vệ nội thất căn hộ, văn phòng.",
    items: [
      { name: "Decal phản quang (Silver)", price: "60.000 - 90.000", unit: "m2" },
      { name: "Phim cách nhiệt Nano Ceramic (Hàn Quốc)", price: "250.000 - 450.000", unit: "m2" },
      { name: "Phim cách nhiệt 3M chính hãng", price: "550.000 - 1.200.000", unit: "m2" },
      { name: "Phim an toàn (Safety Film) chống vỡ kính", price: "180.000 - 320.000", unit: "m2" }
    ],
    image: "/images/Thi-cong-dan-phim-cach-nhiet-van-phong-cong-ty.webp"
  },
  {
    title: "Báo Giá Decal Quảng Cáo & In Ấn",
    link: "/dich-vu/decal-quang-cao/", // Đảm bảo bạn có hoặc sẽ tạo trang này
    description: "In ấn và thi công decal quảng cáo mặt tiền, logo thương hiệu độ sắc nét cao.",
    items: [
      { name: "In Decal sữa/Decal trong (Mực dầu)", price: "120.000 - 180.000", unit: "m2" },
      { name: "In Decal lưới (One-way Vision)", price: "160.000 - 250.000", unit: "m2" },
      { name: "PP ngoài trời có keo (Cán bóng/mờ)", price: "150.000 - 200.000", unit: "m2" },
      { name: "Cắt chữ Decal màu nội ngoại nhập", price: "100.000 - 150.000", unit: "m2" }
    ],
    image: "/images/projects/decal-quang-cao.jpg"
  },
  {
    title: "Dịch Vụ Wrap Nội Thất Cao Cấp",
    link: "/dich-vu/wrap-noi-that/",
    description: "Tân trang tủ bếp, bàn ghế, cửa gỗ bằng film kiến trúc chống trầy, chống thấm.",
    items: [
      { name: "Wrap film vân gỗ/vân đá (Hàn Quốc)", price: "350.000 - 650.000", unit: "m2" },
      { name: "Wrap film màu đơn sắc (Matte/Gloss)", price: "250.000 - 450.000", unit: "m2" },
      { name: "Tháo gỡ decal cũ & vệ sinh keo", price: "20.000 - 45.000", unit: "m2" }
    ],
    image: "/images/projects/wrap-noi-that.jpg"
  }
];

const checklistSEO = [
    "Khảo sát đo đạc mặt bằng miễn phí 100%.",
    "Đội ngũ kỹ thuật viên hơn 5 năm kinh nghiệm.",
    "Sử dụng vật liệu chính hãng, độ bền trên 5 năm.",
    "Thi công sạch sẽ, nhanh chóng, kể cả ngoài giờ hành chính.",
    "Có đầy đủ hóa đơn VAT cho doanh nghiệp."
];
---

<BaseLayout 
  title="Báo Giá Thi Công Decal Dán Kính, Phim Cách Nhiệt & Quảng Cáo TPHCM"
  description="Bảng giá tổng hợp dịch vụ dán decal mờ văn phòng, phim cách nhiệt, decal quảng cáo và wrap nội thất tại TPHCM. Tư vấn báo giá nhanh trong 5 phút."
>
  <section class="relative py-24 bg-slate-900 text-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 relative z-10 text-center md:text-left">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight text-white">
        Báo Giá Tổng Hợp <br/> 
        <span class="text-yellow-500">Thi Công Decal & Phim Cách Nhiệt</span>
      </h1>
      <p class="text-xl text-slate-400 max-w-3xl">
        Cam kết minh bạch về giá cả, vật liệu chính hãng. DecalPro hỗ trợ khảo sát và gửi mẫu tận nơi hoàn toàn miễn phí tại khu vực TP.HCM.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      {pricingSections.map((section, index) => (
        <div class={`flex flex-col lg:flex-row gap-12 mb-24 items-center ${index % 2 !== 0 ? 'lg:flex-row-reverse' : ''}`}>
          <div class="flex-1 w-full">
            <h2 class="text-3xl font-bold mb-4 text-slate-800">{section.title}</h2>
            <p class="text-gray-600 mb-6 leading-relaxed">{section.description}</p>
            
            <div class="overflow-x-auto border border-gray-100 rounded-2xl shadow-sm mb-6">
              <table class="w-full text-left border-collapse">
                <thead class="bg-slate-50 text-slate-700">
                  <tr>
                    <th class="p-4 font-bold">Hạng mục thi công</th>
                    <th class="p-4 font-bold text-right">Đơn giá (VNĐ)</th>
                  </tr>
                </thead>
                <tbody>
                  {section.items.map((item) => (
                    <tr class="border-t border-gray-50 hover:bg-gray-50 transition">
                      <td class="p-4 text-gray-700">{item.name}</td>
                      <td class="p-4 text-right">
                        <span class="font-bold text-slate-900 text-lg">{item.price}</span>
                        <span class="text-gray-400 text-sm italic"> /{item.unit}</span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <div class="flex flex-wrap gap-4 items-center justify-between">
                <a href={section.link} class="inline-flex items-center gap-2 text-slate-900 font-bold hover:text-yellow-600 transition group border-b-2 border-yellow-500 pb-1">
                    Xem dự án mẫu
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform group-hover:translate-x-1 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </a>
                <p class="text-xs text-gray-400 italic font-medium bg-slate-100 px-3 py-1 rounded">Ưu đãi giảm thêm cho diện tích > 50m2</p>
            </div>
          </div>
          
          <div class="flex-1 w-full">
            <div class="relative group">
                <div class="absolute -inset-2 bg-yellow-400 rounded-2xl blur opacity-20 group-hover:opacity-40 transition"></div>
                <img 
                    src={section.image} 
                    alt={section.title} 
                    class="relative rounded-2xl shadow-xl w-full h-[380px] object-cover"
                />
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="py-20 bg-slate-50 px-6">
    <div class="max-w-4xl mx-auto bg-white p-8 md:p-12 rounded-3xl shadow-sm">
        <h2 class="text-3xl font-bold text-center mb-10 text-slate-900">Yếu tố ảnh hưởng đến báo giá</h2>
        <div class="grid md:grid-cols-2 gap-8 text-gray-600">
            <div class="space-y-4">
                <h4 class="font-bold text-slate-800">1. Khối lượng thi công</h4>
                <p class="text-sm">Diện tích càng lớn, DecalPro sẽ áp dụng mức chiết khấu càng cao để tối ưu ngân sách cho khách hàng.</p>
            </div>
            <div class="space-y-4">
                <h4 class="font-bold text-slate-800">2. Độ phức tạp thiết kế</h4>
                <p class="text-sm">Việc cắt logo, kẻ chỉ thủ công hay in UV nhiều lớp đòi hỏi thợ tay nghề cao và thời gian máy chạy CNC lâu hơn.</p>
            </div>
            <div class="space-y-4">
                <h4 class="font-bold text-slate-800">3. Vật liệu lựa chọn</h4>
                <p class="text-sm">Sử dụng Film Hàn Quốc, 3M chính hãng sẽ có giá cao hơn nhưng được bảo hành bong tróc lên đến 5-10 năm.</p>
            </div>
            <div class="space-y-4">
                <h4 class="font-bold text-slate-800">4. Điều kiện thi công</h4>
                <p class="text-sm">Vị trí lắp đặt trên cao (cần giàn giáo) hoặc yêu cầu thi công đêm/lễ sẽ có thêm phụ phí hỗ trợ thợ.</p>
            </div>
        </div>
    </div>
  </section>

  <section class="py-20 bg-white px-6">
    <div class="max-w-7xl mx-auto border-2 border-dashed border-slate-200 rounded-3xl p-8 md:p-16">
        <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
                <h2 class="text-3xl font-bold mb-8">Cam kết từ DecalPro</h2>
                <ul class="space-y-4">
                    {checklistSEO.map(item => (
                        <li class="flex items-center gap-3">
                            <span class="text-green-500 text-xl font-bold">✓</span>
                            <span class="text-gray-700 font-medium">{item}</span>
                        </li>
                    ))}
                </ul>
            </div>
            <div class="bg-slate-900 rounded-2xl p-8 text-white">
                <h3 class="text-2xl font-bold mb-4 text-yellow-500">Đặt lịch khảo sát ngay!</h3>
                <p class="text-slate-400 mb-8 text-sm">Chụp ảnh mặt bằng và gửi qua Zalo, chúng tôi sẽ tư vấn phương án thi công đẹp nhất và báo giá trọn gói.</p>
                <a href="https://zalo.me/0862208108" class="block w-full text-center bg-yellow-500 text-black py-4 rounded-xl font-bold text-xl hover:bg-yellow-400 transition-all shadow-xl">
                    📞 Zalo: 0862 208 108
                </a>
            </div>
        </div>
    </div>
  </section>
</BaseLayout>
