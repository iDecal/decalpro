---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Dữ liệu cho các hạng mục dịch vụ con
const subServices = [
  {
    title: "Dán decal mờ toàn phần",
    description: "Giải pháp che chắn tuyệt đối cho phòng họp, phòng sếp, tạo sự tập trung tối đa.",
    icon: "🏢"
  },
  {
    title: "Cắt chữ, Logo CNC",
    description: "Khẳng định thương hiệu ngay từ cửa ra vào với logo được cắt tỉ mỉ bằng máy CNC.",
    icon: "🎯"
  },
  {
    title: "Decal kẻ chỉ hiện đại",
    description: "Tạo các đường kẻ ngang dọc tinh tế, giúp không gian văn phòng thông thoáng và sang trọng.",
    icon: "📏"
  },
  {
    title: "Decal 3D sóng (Wave)",
    description: "Sản phẩm cao cấp với bề mặt dập nổi, xuyên sáng 20-30%, tạo hiệu ứng ánh sáng đẳng cấp.",
    icon: "🌊"
  }
];

// Schema FAQ chuẩn SEO
const faqData = [
  {
    q: "Có tháo được decal cũ khi muốn thay đổi không?",
    a: "Hoàn toàn được. Chúng tôi có dịch vụ tháo gỡ chuyên nghiệp, xử lý sạch lớp keo cũ mà không làm trầy xước kính."
  },
  {
    q: "Thời gian thi công cho một văn phòng thường mất bao lâu?",
    a: "Với các văn phòng từ 20-50m2, đội ngũ chúng tôi thường hoàn thiện trong vòng 3-5 giờ làm việc."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
---

<BaseLayout 
  title="Thi Công Decal Dán Kính Văn Phòng TP.HCM - Chuyên Nghiệp & Sắc Nét"
  description="Chuyên dán decal mờ văn phòng, cắt logo công ty, dán phim cách nhiệt tại TP.HCM. Khảo sát miễn phí, thi công nhanh 24/7."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />

  <section class="relative py-24 bg-slate-900 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
      <div class="text-white">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">
          Dịch Vụ Thi Công <span class="text-yellow-400">Decal Dán Kính</span> Văn Phòng Trọn Gói
        </h1>
        <p class="text-lg text-slate-300 mb-8">
          Nâng tầm diện mạo doanh nghiệp với giải pháp dán kính mờ chuyên nghiệp. Sắc nét từng đường cắt - Bền bỉ theo thời gian.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="tel:0862208108" class="bg-yellow-500 text-black px-8 py-4 rounded-full font-bold hover:scale-105 transition shadow-lg">Liên hệ ngay: 0862 208 108</a>
        </div>
      </div>
      <div class="relative">
        <img src="/images/projects/vcb-quan-1.jpg" alt="Thi công decal văn phòng" class="rounded-3xl shadow-2xl border-8 border-white/5" />
      </div>
    </div>
  </section>

  <section class="py-20 bg-white px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold mb-4">Giải pháp tối ưu cho vách kính</h2>
        <div class="w-20 h-1 bg-yellow-500 mx-auto"></div>
      </div>
      
      <div class="grid md:grid-cols-4 gap-8">
        {subServices.map(item => (
          <div class="p-8 bg-gray-50 rounded-2xl hover:bg-white hover:shadow-xl transition-all border border-transparent hover:border-yellow-400">
            <div class="text-4xl mb-4">{item.icon}</div>
            <h3 class="text-xl font-bold mb-3">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-50 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">Quy trình làm việc chuyên nghiệp</h2>
      <div class="space-y-8">
        {[
          { step: "01", title: "Khảo sát & Tư vấn", desc: "Kỹ thuật viên tới tận văn phòng đo đạc và mang mẫu thực tế để bạn chọn lựa." },
          { step: "02", title: "Thiết kế & Demo", desc: "Lên phối cảnh 2D/3D cho logo và các mảng trang trí để bạn duyệt trước." },
          { step: "03", title: "Thi công sắc nét", desc: "Đội ngũ thợ giàu kinh nghiệm trực tiếp dán và xử lý các góc cạnh tinh tế." },
          { step: "04", title: "Nghiệm thu & Bảo hành", desc: "Kiểm tra kỹ lưỡng và bàn giao phiếu bảo hành kỹ thuật 2 năm." }
        ].map(item => (
          <div class="flex items-start gap-6 bg-white p-6 rounded-xl shadow-sm">
            <span class="text-4xl font-black text-yellow-500/20">{item.step}</span>
            <div>
              <h4 class="font-bold text-lg mb-1">{item.title}</h4>
              <p class="text-gray-600">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-6 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">Câu hỏi thường gặp</h2>
      <div class="space-y-6">
        {faqData.map(faq => (
          <div class="border-b pb-6">
            <h4 class="font-bold text-lg mb-2 flex gap-2">
              <span class="text-yellow-600">Q:</span> {faq.q}
            </h4>
            <p class="text-gray-600 pl-6">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-yellow-400 py-16 text-center px-6">
    <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold mb-6">Bạn cần thợ khảo sát mẫu tại văn phòng ngay hôm nay?</h2>
        <p class="text-lg mb-8">Chúng tôi có mặt trong 30-60 phút tại các quận nội thành TP.HCM.</p>
        <a href="tel:0862208108" class="bg-slate-900 text-white px-10 py-4 rounded-full font-bold text-xl inline-block hover:scale-110 transition shadow-2xl">
            Gọi tư vấn miễn phí: 0862 208 108
        </a>
    </div>
  </section>
</BaseLayout>
