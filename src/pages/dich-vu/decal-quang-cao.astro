---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Dữ liệu các loại decal quảng cáo
const adServices = [
  {
    title: "Dán Decal Logo Mặt Tiền",
    desc: "Thi công bộ chữ, logo thương hiệu trên kính hoặc Alu với độ chính xác cực cao, bền màu ngoài trời.",
    image: "/images/projects/thi-cong-decal-logo-sala-quan-2.jpg",
    tag: "Nổi bật"
  },
  {
    title: "Decal Lưới (One-way Vision)",
    desc: "Hiển thị hình ảnh quảng cáo rực rỡ bên ngoài nhưng vẫn đảm bảo tầm nhìn thông thoáng từ bên trong.",
    image: "/images/projects/1.jpeg", // Thay bằng ảnh decal lưới thực tế của bạn
    tag: "Độc đáo"
  },
  {
    title: "Decal Trong In UV",
    desc: "Công nghệ in UV trên decal trong suốt tạo hiệu ứng hình ảnh sắc nét, sang trọng như in trực tiếp lên kính.",
    image: "/images/projects/2.jpeg", // Thay bằng ảnh decal trong thực tế của bạn
    tag: "Cao cấp"
  }
];

const faqData = [
  {
    q: "Decal quảng cáo ngoài trời có bị bay màu không?",
    a: "Chúng tôi sử dụng mực in UV và màng bảo vệ chuyên dụng giúp màu sắc bền bỉ từ 2-3 năm dưới điều kiện nắng mưa khắc nghiệt."
  },
  {
    q: "Tôi chưa có file thiết kế, công ty có hỗ trợ không?",
    a: "Có. Đội ngũ thiết kế của chúng tôi sẽ hỗ trợ lên mẫu demo, canh chỉnh kích thước logo sao cho phù hợp nhất với mặt tiền của bạn."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Thi công decal quảng cáo showroom",
  "description": "Dịch vụ dán decal quảng cáo, decal lưới, in UV và dán logo mặt tiền cửa hàng chuyên nghiệp tại TP.HCM.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "DecalPro"
  }
};
---

<BaseLayout 
  title="Thi Công Decal Quảng Cáo Showroom & Cửa Hàng - Đẹp & Sắc Nét"
  description="Dịch vụ dán decal quảng cáo mặt tiền, decal lưới, dán logo công ty chuyên nghiệp tại TP.HCM. In UV sắc nét, thi công nhanh, giá tận xưởng."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <section class="relative py-24 bg-gradient-to-r from-slate-900 via-purple-900 to-slate-900 text-white px-6 overflow-hidden">
    <div class="max-w-7xl mx-auto text-center relative z-10">
      <span class="bg-yellow-500 text-black px-4 py-1 rounded-full text-sm font-bold uppercase mb-6 inline-block">Giải pháp thương hiệu</span>
      <h1 class="text-4xl md:text-6xl font-black mb-6 leading-tight">
        Nâng Tầm Showroom Với <br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 to-orange-500">Decal Quảng Cáo</span> Đẳng Cấp
      </h1>
      <p class="text-slate-300 text-lg mb-10 max-w-2xl mx-auto">
        Chuyên thi công decal logo mặt tiền, decal lưới và trang trí sự kiện cho các thương hiệu lớn. Cam kết độ sắc nét chuẩn thiết kế.
      </p>
      <a href="tel:0862208108" class="bg-white text-slate-900 px-10 py-4 rounded-full font-bold text-lg hover:bg-yellow-400 transition transform hover:scale-105 inline-block shadow-2xl">
        Báo giá thi công ngay
      </a>
    </div>
  </section>

  <section class="py-20 bg-white px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-3 gap-10">
        {adServices.map(service => (
          <div class="group bg-gray-50 rounded-3xl overflow-hidden border border-gray-100 hover:shadow-2xl transition-all duration-300">
            <div class="relative h-64 overflow-hidden">
              <img src={service.image} alt={service.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
              <div class="absolute top-4 left-4 bg-black/70 text-white text-xs font-bold px-3 py-1 rounded-full">{service.tag}</div>
            </div>
            <div class="p-8">
              <h3 class="text-2xl font-bold mb-4 text-slate-800">{service.title}</h3>
              <p class="text-gray-600 leading-relaxed mb-6">{service.desc}</p>
              <div class="w-12 h-1 bg-yellow-500 group-hover:w-full transition-all duration-500"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-50 px-6">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-slate-900">Tiêu chuẩn thi công <br/> khắt khe cho Showroom</h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="w-12 h-12 bg-yellow-400 rounded-full flex items-center justify-center font-bold flex-shrink-0">1</div>
            <p class="text-gray-700">**Mực in cao cấp:** Sử dụng mực in Nhật Bản chính hãng, chống tia UV, không mùi, an toàn cho không gian kín.</p>
          </div>
          <div class="flex gap-4">
            <div class="w-12 h-12 bg-yellow-400 rounded-full flex items-center justify-center font-bold flex-shrink-0">2</div>
            <p class="text-gray-700">**Kỹ thuật dán khô/ướt:** Tùy bề mặt mà thợ có kỹ thuật dán phù hợp, đảm bảo không một vết bọt khí hay bụi bẩn lọt vào.</p>
          </div>
          <div class="flex gap-4">
            <div class="w-12 h-12 bg-yellow-400 rounded-full flex items-center justify-center font-bold flex-shrink-0">3</div>
            <p class="text-gray-700">**Đúng tiến độ:** Chúng tôi hiểu thời gian khai trương là "vàng", cam kết thi công đúng hoặc sớm hơn tiến độ.</p>
          </div>
        </div>
      </div>
      <div class="bg-slate-900 p-2 rounded-3xl rotate-2">
        <img src="/images/projects/toyota-q7.jpg" alt="Dự án dán decal showroom" class="rounded-2xl shadow-xl -rotate-2 hover:rotate-0 transition-transform duration-500" />
      </div>
    </div>
  </section>

  <section class="py-20 bg-white px-6">
    <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl font-bold">Giải đáp thắc mắc</h2>
    </div>
    <div class="max-w-3xl mx-auto space-y-6">
      {faqData.map(faq => (
        <div class="bg-gray-50 p-6 rounded-2xl border-l-8 border-yellow-500 shadow-sm">
          <h4 class="font-bold text-lg mb-2">{faq.q}</h4>
          <p class="text-gray-600 italic">“{faq.a}”</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-20 bg-yellow-400 text-center px-6">
    <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-black mb-6 uppercase">Sẵn sàng bùng nổ doanh số?</h2>
        <p class="text-lg mb-10 font-medium">Để lại ấn tượng mạnh mẽ với khách hàng ngay từ cái nhìn đầu tiên.</p>
        <div class="flex flex-wrap justify-center gap-4">
            <a href="tel:0862208108" class="bg-slate-900 text-white px-10 py-4 rounded-full font-bold text-xl hover:bg-black transition shadow-xl">
                Gọi ngay: 0862 208 108
            </a>
            <a href="/lien-he" class="bg-white text-slate-900 px-10 py-4 rounded-full font-bold text-xl hover:bg-gray-100 transition shadow-xl border-2 border-slate-900">
                Gửi yêu cầu thiết kế
            </a>
        </div>
    </div>
  </section>
</BaseLayout>
