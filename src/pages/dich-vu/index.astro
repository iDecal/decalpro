---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { districtMega } from "../../lib/districtMega";

// Bạn có thể thêm mảng các dịch vụ chính ở đây để hiển thị
const mainServices = [
  {
    title: "Dán kính văn phòng",
    desc: "Giải pháp tạo không gian riêng tư, chuyên nghiệp cho doanh nghiệp.",
    icon: "🏢",
    link: "/dich-vu/decal-dan-kinh-van-phong"
  },
  {
    title: "Chống nắng cách nhiệt",
    desc: "Giảm nhiệt độ phòng, bảo vệ sức khỏe và nội thất khỏi tia UV.",
    icon: "☀️",
    link: "/dich-vu/decal-chong-nang-cach-nhiet"
  },
  {
    title: "Decal quảng cáo",
    desc: "Thiết kế và thi công cắt dán logo, slogan theo yêu cầu.",
    icon: "✂️",
    link: "#"
  },
  {
    title: "Wrap nội thất",
    desc: "Thiết kế và thi công cắt dán logo, slogan theo yêu cầu.",
    icon: "✂️",
    link: "#"
  }
];
---

<BaseLayout 
  title="Dịch vụ thi công decal dán kính chuyên nghiệp tại TP.HCM"
  description="Decal Pro chuyên thi công dán kính văn phòng, chống nắng, decal trang trí tận nơi tại tất cả các quận huyện TP.HCM. Khảo sát miễn phí."
>
  <section class="bg-slate-900 text-white py-20 px-6 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6">
        Dịch Vụ Thi Công Decal Chuyên Nghiệp
      </h1>
      <p class="text-xl text-slate-300 mb-8">
        Khảo sát nhanh - Thi công tỉ mỉ - Bảo hành dài hạn tại mọi khu vực TP.HCM.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="tel:0909000000" class="bg-yellow-400 text-black px-8 py-3 rounded-full font-bold text-lg hover:bg-yellow-500 transition">
          Gọi tư vấn: 0909 000 000
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 max-w-7xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-center mb-12">Các dịch vụ trọng tâm</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {mainServices.map(service => (
        <div class="border rounded-2xl p-8 hover:shadow-xl transition-shadow bg-white">
          <div class="text-4xl mb-4">{service.icon}</div>
          <h3 class="text-xl font-bold mb-3">{service.title}</h3>
          <p class="text-gray-600 mb-6">{service.desc}</p>
          <a href={service.link} class="text-blue-600 font-semibold hover:underline">Tìm hiểu thêm →</a>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-gray-50 py-16 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold">Khu vực thi công tận nơi</h2>
        <p class="text-gray-600 mt-2">Chúng tôi có đội ngũ kỹ thuật phủ khắp các quận huyện</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        {districtMega.map((group) => (
          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
            <h3 class="text-xl font-bold text-blue-800 mb-6 border-b pb-2">
              {group.title}
            </h3>
            <ul class="grid grid-cols-2 gap-y-3">
              {group.districts.map((d) => (
                <li>
                  <a 
                    href={`/thi-cong-decal/${d.slug}`}
                    class="text-gray-700 hover:text-yellow-600 transition flex items-center gap-2"
                  >
                    <span class="w-1 h-1 bg-yellow-500 rounded-full"></span>
                    {d.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 text-center max-w-4xl mx-auto px-6">
    <h2 class="text-2xl font-bold mb-8">Tại sao chọn dịch vụ của chúng tôi?</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <div>
        <div class="font-bold text-3xl text-yellow-500 mb-2">10+</div>
        <div class="text-sm text-gray-600">Năm kinh nghiệm</div>
      </div>
      <div>
        <div class="font-bold text-3xl text-yellow-500 mb-2">1h</div>
        <div class="text-sm text-gray-600">Khảo sát nhanh</div>
      </div>
      <div>
        <div class="font-bold text-3xl text-yellow-500 mb-2">100%</div>
        <div class="text-sm text-gray-600">Thợ lành nghề</div>
      </div>
      <div>
        <div class="font-bold text-3xl text-yellow-500 mb-2">2 Năm</div>
        <div class="text-sm text-gray-600">Bảo hành thi công</div>
      </div>
    </div>
  </section>
</BaseLayout>
