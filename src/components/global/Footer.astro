---
const { districtName, slug } = Astro.props;

const relatedDistricts = [
  { name: "Quận 1", slug: "quan-1" },
  { name: "Quận 3", slug: "quan-3" },
  { name: "Bình Thạnh", slug: "binh-thanh" },
  { name: "TP Thủ Đức", slug: "thu-duc" },
  { name: "Tân Bình", slug: "tan-binh" },
  { name: "Quận 7", slug: "quan-7" },
];
---

<footer class="bg-gray-900 text-white mt-16">
  <div class="max-w-7xl mx-auto px-6 py-14 grid md:grid-cols-3 gap-10">

    <!-- SEO text -->
    <div>
      <h3 class="text-xl font-bold mb-4">
        Thi công decal dán kính {districtName}
      </h3>
      <p class="text-gray-300 leading-relaxed text-sm">
        Decal Pro cung cấp dịch vụ thi công decal dán kính tại {districtName}
        với giải pháp tối ưu cho văn phòng, cửa hàng, nhà ở và showroom.
        Đội ngũ thi công nhanh chóng, thẩm mỹ cao, hỗ trợ khảo sát tận nơi
        trên toàn khu vực TP.HCM.
      </p>
    </div>

    <!-- Internal links -->
    <div>
      <h3 class="text-xl font-bold mb-4">
        Khu vực thi công nổi bật
      </h3>
      <ul class="space-y-2 text-sm text-gray-300">
        {relatedDistricts
          .filter((item) => item.slug !== slug)
          .map((item) => (
            <li>
              <a
                href={`/thi-cong-decal/${item.slug}`}
                class="hover:text-yellow-400 transition"
              >
                Thi công decal dán kính {item.name}
              </a>
            </li>
          ))}
      </ul>
    </div>

    <!-- Company info -->
    <div>
      <h3 class="text-xl font-bold mb-4">Decal Pro</h3>
      <p class="text-sm text-gray-300 leading-relaxed">
        Chuyên thi công decal kính mờ, decal trang trí, decal chống nắng
        cho doanh nghiệp và hộ gia đình tại TP.HCM.
      </p>
      <p class="mt-3 text-yellow-400 font-semibold">
        Hotline: 0909 000 000
      </p>
    </div>
  </div>

  <div class="border-t border-gray-800 text-center text-sm text-gray-400 py-4">
    © 2026 Decal Pro - Thi công decal dán kính tại {districtName}
  </div>
</footer>
