          <div class="bg-slate-800/50 p-3 rounded-lg border border-slate-700">
            <p class="text-[10px] uppercase text-slate-500 font-bold">Hotline tư vấn</p>
            <a href="tel:0862208108" class="text-white text-xl font-black hover:text-yellow-500 transition-colors">0862.208.108</a>
          </div>
          <p class="text-xs flex items-center gap-2">
            <span class="text-yellow-500">✉️</span> contact@thicongdecal.pro
          </p>
        </div>
      </div>
    </div>

    <div class="pt-8 border-t border-slate-800/50 flex flex-col md:flex-row justify-between items-center gap-4 text-[11px] text-slate-500">
      <p>© {currentYear} <strong>thicongdecal.pro</strong>. Một sản phẩm của <a href="https://idecal.vn" class="hover:text-white">iDecal.vn</a></p>
      <div class="flex gap-6 uppercase tracking-tighter">
