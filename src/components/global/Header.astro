---
const districtMega = [
  {
    title: "Khu trung tâm",
    districts: [
      { name: "Quận 1", slug: "quan-1" },
      { name: "Quận 3", slug: "quan-3" },
      { name: "Quận 5", slug: "quan-5" },
      { name: "Quận 10", slug: "quan-10" }
    ]
  },
  {
    title: "Khu Đông",
    districts: [
      { name: "Thủ Đức", slug: "thu-duc" },
      { name: "Quận 2", slug: "quan-2" },
      { name: "Quận 9", slug: "quan-9" }
    ]
  }
];
---

<header class="sticky top-0 z-50 bg-white border-b shadow-sm">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- 🌿 LOGO -->
    <a href="/" class="flex items-center gap-2">
      <img src="/images/logo.png" alt="Decal Pro" class="h-10 w-auto" />
      <span class="font-bold text-lg">Decal Pro</span>
    </a>

    <!-- 🌿 MENU -->
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium">

      <a href="/" class="hover:text-yellow-500">Trang chủ</a>
      <a href="/dich-vu" class="hover:text-yellow-500">Dịch vụ</a>

      <!-- Mega menu -->
      <div class="relative group">

        <span class="cursor-pointer hover:text-yellow-500">
          Thi công theo quận
        </span>

        <div class="absolute left-1/2 -translate-x-1/2 top-full hidden group-hover:block w-[900px] bg-white shadow-2xl rounded-xl p-6">

          <div class="grid grid-cols-2 gap-8">

            {districtMega.map(col => (
              <div>
                <h3 class="font-semibold mb-3 text-gray-900">{col.title}</h3>
                {col.districts.map(d => (
                  <a href={`/thi-cong-decal/${d.slug}`} class="block text-sm text-gray-600 hover:text-black py-1">
                    {d.name}
                  </a>
                ))}
              </div>
            ))}

          </div>

        </div>

      </div>

      <a href="/du-an" class="hover:text-yellow-500">Dự án</a>
      <a href="/blog" class="hover:text-yellow-500">Blog</a>
      <a href="/lien-he" class="hover:text-yellow-500">Liên hệ</a>

    </nav>

    <!-- 🌿 CTA BUTTON -->
    <a href="/lien-he"
       class="hidden md:inline-block bg-yellow-400 hover:bg-yellow-500 text-black font-semibold px-5 py-2 rounded-lg shadow">
      Báo giá miễn phí
    </a>

    <!-- 🌿 MOBILE BUTTON -->
    <button onclick="toggleMenu()" class="md:hidden text-2xl">
      ☰
    </button>

  </div>

  <!-- 🌿 MOBILE MENU -->
  <div id="mobile-menu" class="hidden md:hidden px-6 pb-6 border-t">

    <a href="/" class="block py-2">Trang chủ</a>
    <a href="/dich-vu" class="block py-2">Dịch vụ</a>
    <a href="/thi-cong-decal" class="block py-2">Thi công theo quận</a>
    <a href="/du-an" class="block py-2">Dự án</a>
    <a href="/blog" class="block py-2">Blog</a>
    <a href="/lien-he" class="block py-2">Liên hệ</a>

    <a href="/lien-he"
       class="block mt-4 text-center bg-yellow-400 py-2 rounded-lg font-semibold">
      Báo giá miễn phí
    </a>

  </div>
</header>

<script>
  function toggleMenu() {
    const menu = document.getElementById("mobile-menu");
    if (menu) menu.classList.toggle("hidden");
  }
</script>
