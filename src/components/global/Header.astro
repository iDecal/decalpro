---
const districtMega = [
  {
    title: "Khu trung tâm",
    districts: [
      { name: "Quận 1", slug: "quan-1" },
      { name: "Quận 3", slug: "quan-3" },
      { name: "Quận 4", slug: "quan-4" },
      { name: "Quận 5", slug: "quan-5" },
      { name: "Quận 6", slug: "quan-6" },
      { name: "Quận 8", slug: "quan-8" },
      { name: "Quận 10", slug: "quan-10" },
      { name: "Quận 11", slug: "quan-11" }
    ]
  },
  {
    title: "Khu Đông",
    districts: [
      { name: "TP Thủ Đức", slug: "thu-duc" },
      { name: "Quận 2", slug: "quan-2" },
      { name: "Quận 9", slug: "quan-9" },
      { name: "Bình Thạnh", slug: "binh-thanh" },
      { name: "Phú Nhuận", slug: "phu-nhuan" }
    ]
  },
  {
    title: "Khu Tây",
    districts: [
      { name: "Tân Bình", slug: "tan-binh" },
      { name: "Tân Phú", slug: "tan-phu" },
      { name: "Bình Tân", slug: "binh-tan" },
      { name: "Quận 12", slug: "quan-12" }
    ]
  },
  {
    title: "Khu Nam",
    districts: [
      { name: "Quận 7", slug: "quan-7" },
      { name: "Nhà Bè", slug: "nha-be" },
      { name: "Cần Giờ", slug: "can-gio" }
    ]
  },
  {
    title: "Ngoại thành",
    districts: [
      { name: "Hóc Môn", slug: "hoc-mon" },
      { name: "Củ Chi", slug: "cu-chi" },
      { name: "Bình Chánh", slug: "binh-chanh" }
    ]
  }
];

function toggleMenu() {
  const menu = document.getElementById("mobile-menu");
  if (menu) menu.classList.toggle("hidden");
}

function toggleAccordion(id) {
  const el = document.getElementById("accordion-" + id);
  const icon = document.getElementById("icon-" + id);
  if (!el) return;

  el.classList.toggle("hidden");
  if (icon) icon.innerText = el.classList.contains("hidden") ? "+" : "-";
}
---

<header class="sticky top-0 z-50 bg-white border-b">
  <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">

    <a href="/" class="font-bold text-lg">Decal Pro</a>

    <!-- Desktop -->
    <nav class="hidden md:flex gap-8 text-sm">

      <a href="/">Trang chủ</a>
      <a href="/dich-vu">Dịch vụ</a>

      <!-- Mega -->
      <div class="relative group">

        <span class="cursor-pointer">Thi công theo quận</span>

        <div class="absolute left-1/2 -translate-x-1/2 top-full hidden group-hover:block w-[1000px] bg-white shadow-xl p-6">

          <div class="grid grid-cols-5 gap-6">

            {districtMega.map(col => (
              <div>
                <h3 class="font-semibold mb-3">{col.title}</h3>
                {col.districts.map(d => (
                  <a href={`/thi-cong-decal/${d.slug}`} class="block text-sm text-gray-600 hover:text-black">
                    {d.name}
                  </a>
                ))}
              </div>
            ))}

          </div>

        </div>

      </div>

      <a href="/du-an">Dự án</a>
      <a href="/blog">Blog</a>
      <a href="/lien-he">Liên hệ</a>

    </nav>

    <!-- Mobile Button -->
    <button onclick="toggleMenu()" class="md:hidden text-xl">
      ☰
    </button>

  </div>

  <!-- MOBILE -->
  <div id="mobile-menu" class="hidden md:hidden px-6 pb-6 border-t">

    <a href="/" class="block py-2">Trang chủ</a>
    <a href="/dich-vu" class="block py-2">Dịch vụ</a>

    <button onclick="toggleAccordion('district')" class="w-full flex justify-between py-2">
      Thi công theo quận
      <span id="icon-district">+</span>
    </button>

    <div id="accordion-district" class="hidden pl-4">

      {districtMega.map((col, i) => (
        <div>

          <button onclick={`toggleAccordion('col-${i}')`} class="w-full flex justify-between py-1 text-sm font-semibold">
            {col.title}
            <span id={`icon-col-${i}`}>+</span>
          </button>

          <div id={`accordion-col-${i}`} class="hidden pl-4">

            {col.districts.map(d => (
              <a href={`/thi-cong-decal/${d.slug}`} class="block text-sm py-1">
                {d.name}
              </a>
            ))}

          </div>

        </div>
      ))}

    </div>

    <a href="/du-an" class="block py-2">Dự án</a>
    <a href="/blog" class="block py-2">Blog</a>
    <a href="/lien-he" class="block py-2">Liên hệ</a>

  </div>

</header>
